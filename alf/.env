# alf — environment variables for site credentials and FX providers
# Copy this file, fill in real values. Never commit credentials.

# eBay API (auctions module — used by ebay_motors_uk and ebay_motors_us)
# Register at https://developer.ebay.com
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=

# Classifieds: AutoTrader UK
# Register at https://developer.autotrader.co.uk
AUTOTRADER_CLIENT_ID=
AUTOTRADER_CLIENT_SECRET=

# Classifieds: Exchange & Mart
EXCHANGE_MART_API_KEY=

# Classifieds: Motors.co.uk
MOTORS_API_KEY=

# Classifieds: PistonHeads
# Apply for partner API access at https://www.pistonheads.com/developers
PISTONHEADS_API_KEY=

# Classifieds: Bring a Trailer (US auctions)
# Apply for partner API access at https://bringatrailer.com/developers
BRING_A_TRAILER_API_KEY=

# Classifieds: Cars and Bids (US auctions)
# Apply for partner API access at https://carsandbids.com/api
CARS_AND_BIDS_API_KEY=

# Classifieds: Car and Classic
# Apply for partner API access at https://www.carandclassic.com/partners
CARANDCLASSIC_API_KEY=

# FX provider — only needed when provider != "frankfurter" (frankfurter is free, no key)
# Open Exchange Rates: https://openexchangerates.org (set provider to "openexchangerates")
OPENEXCHANGERATES_APP_ID=
# Fixer.io: https://fixer.io (set provider to "fixer"; non-EUR base requires paid plan)
FIXER_ACCESS_KEY=
